# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Proxied through Next.js rewrites — see next.config.ts
NEXT_PUBLIC_API_URL=/api

# Backend server URL (used by Next.js rewrites only, not exposed to browser)
BACKEND_URL=http://localhost:2000

# Without NEXT_PUBLIC_API_URL, dev mock login and room state still work locally.
